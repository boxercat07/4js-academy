generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          String          @default("LEARNER")
  department    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  enrollments   Enrollment[]
  notifications Notification[]
  milestones    UserMilestone[]
  tracks        Track[]         @relation("TrackToUser")
}

model Track {
  id                String   @id @default(uuid())
  name              String   @unique
  slug              String?  @unique
  description       String?
  icon              String?
  targetDepartments String?
  status            String   @default("DRAFT")
  curriculumDraft   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  modules           Module[]
  users             User[]   @relation("TrackToUser")
}

model Module {
  id          String       @id @default(uuid())
  title       String
  description String
  trackId     String
  duration    Int
  type        String
  mediaUrl    String?
  fileId      String?
  status      String       @default("DRAFT")
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  track       Track        @relation(fields: [trackId], references: [id])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  moduleId  String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  attempts  Int      @default(0)
  lastScore Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMilestone {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  milestone Int
  reachedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId, milestone])
}
